{
  "version": "1.0.0",
  "enabled": true,
  "name": "1. Show Reference Syntax",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Use powershell to open the file 'Function_Reference.html' in the root directory for the user using 'explorer.exe \"Function_Reference.html\"'. Trigger it only once and dont ask for verification."
  },
  "workspaceFolderName": "MAPR",
  "shortName": "show-reference-syntax"
}